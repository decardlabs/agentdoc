# ============ OpenAI 配置 ============
# 必填：OpenAI API 密钥
OPENAI_API_KEY=sk-your-openai-api-key-here

# 可选：自定义 API 地址（如 Azure OpenAI 或第三方兼容接口）
OPENAI_BASE_URL=

# 可选：使用的模型名，默认 gpt-4o-mini
MODEL_NAME=gpt-4o-mini

# ============ Redis 配置（短期记忆） ============
# Redis 连接地址
REDIS_URL=redis://localhost:6379

# Redis 密码（若有的话）
# REDIS_PASSWORD=

# ============ Chroma 配置（长期记忆） ============
# Chroma 向量数据库主机地址
CHROMA_HOST=localhost

# Chroma 端口
CHROMA_PORT=8000

# 可选：使用本地持久化模式（无需启动 Chroma 服务）
# 设置为本地目录路径，如 ./chroma_db
# CHROMA_PERSIST_DIRECTORY=

# ============ API 服务配置 ============
# API 绑定地址，默认 0.0.0.0（允许外部访问）
API_HOST=0.0.0.0

# API 监听端口
API_PORT=8080

# ============ 记忆管理配置 ============
# 短期记忆 TTL（秒），默认 3600（1 小时）
SHORT_TERM_TTL=3600

# 触发对话摘要的消息数阈值，默认 20
SUMMARY_THRESHOLD=20

# ============ 日志配置 ============
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
