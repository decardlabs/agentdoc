# Obsidian 知识助手环境变量配置模板
# 复制此文件为 .env 并填写实际值

# === Obsidian 配置 ===
# Obsidian Vault 路径（本地开发）
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# === LLM 配置 ===
# OpenAI API Key
OPENAI_API_KEY=sk-your_openai_key_here

# LLM 模型 (可选: gpt-4o-mini, gpt-4o, claude-3.5-sonnet)
LLM_MODEL=gpt-4o-mini

# 嵌入模型 (可选: text-embedding-3-small, text-embedding-3-large)
EMBEDDING_MODEL=text-embedding-3-small

# === 应用配置 ===
# 服务端口
APP_PORT=8000

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# === 向量数据库配置 ===
# ChromaDB URL（如果使用）
CHROMA_URL=http://chroma:8000

# 是否使用语义搜索
USE_SEMANTIC_SEARCH=true

# === 数据库配置 ===
# Redis URL
REDIS_URL=redis://redis:6379/0

# === 搜索配置 ===
# 关键词搜索权重
KEYWORD_SEARCH_WEIGHT=0.5

# 语义搜索权重
SEMANTIC_SEARCH_WEIGHT=0.5

# 相似度阈值
SIMILARITY_THRESHOLD=0.7

# === 高级配置 ===
# 最大上下文长度（字符）
MAX_CONTEXT_LENGTH=10000

# 最大返回结果数
MAX_SEARCH_RESULTS=10

# 总结长度限制
SUMMARIZE_MAX_LENGTH=1000

# === 安全配置 ===
# 允许读取的文件扩展名
ALLOWED_EXTENSIONS=.md,.txt,.pdf

# 阻止读取的路径（逗号分隔）
BLOCKED_PATHS=.trash,.git
