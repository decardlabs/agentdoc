# GitHub Code Review Agent 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# === GitHub 配置 ===
# GitHub Personal Access Token (需要 repo 权限)
GITHUB_TOKEN=ghp_your_github_token_here

# GitHub Webhook Secret (在 GitHub Webhook 配置中设置，用于验证签名)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# === LLM 配置 ===
# OpenAI API Key
OPENAI_API_KEY=sk-your_openai_key_here

# LLM 模型 (可选: gpt-4o-mini, gpt-4o, claude-3.5-sonnet)
LLM_MODEL=gpt-4o-mini

# === 应用配置 ===
# 服务端口（默认 8001，避免与其他主题冲突）
APP_PORT=8001

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 审查级别 (basic, normal, strict)
REVIEW_LEVEL=normal

# === 数据库配置 ===
# Redis URL
REDIS_URL=redis://redis:6379/0

# === 监控配置 ===
# Prometheus 指标端点
ENABLE_METRICS=true

# === Grafana 配置 ===
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# === 安全配置 ===
# 允许仓库列表 (逗号分隔，留空表示允许所有)
ALLOWED_REPOS=

# 阻止关键词 (逗号分隔)
BLOCKED_KEYWORDS=

# === 高级配置 ===
# 最大 diff 大小 (字节)
MAX_DIFF_SIZE=50000

# 最大文件数
MAX_FILES=50

# 审查超时 (秒)
REVIEW_TIMEOUT=300

# === Webhook 配置 ===
# Webhook 通知 URL (可选，用于发送审查结果)
NOTIFICATION_URL=

# Webhook 通知密钥
NOTIFICATION_SECRET=
