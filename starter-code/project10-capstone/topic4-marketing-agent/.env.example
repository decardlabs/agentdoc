# 营销内容生成 Agent 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# === LLM 配置 ===
# OpenAI API Key
OPENAI_API_KEY=sk-your_openai_key_here

# LLM 模型 (可选: gpt-4o-mini, gpt-4o, claude-3.5-sonnet)
LLM_MODEL=gpt-4o-mini

# 图像生成模型 (可选: dall-e-3, dall-e-2)
IMAGE_MODEL=dall-e-3

# === 应用配置 ===
# 服务端口（默认 8004，避免与其他主题冲突）
APP_PORT=8004

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# === 内容生成配置 ===
# 默认内容类型 (wechat, xiaohongshu, weibo, email, blog)
DEFAULT_CONTENT_TYPE=wechat

# 默认语气 (professional, casual, funny, inspirational)
DEFAULT_TONE=professional

# 默认长度（字数）
DEFAULT_LENGTH=800

# 生成温度（0.0-2.0，越高越有创意）
TEMPERATURE=0.7

# === SEO 配置 ===
# 关键词密度目标（%）
KEYWORD_DENSITY_TARGET=1.5

# 最小内容长度
MIN_CONTENT_LENGTH=300

# === 图像生成配置 ===
# 是否启用图像生成
ENABLE_IMAGE_GENERATION=true

# 图像大小 (256x256, 512x512, 1024x1024)
IMAGE_SIZE=1024x1024

# === 数据库配置 ===
# Redis URL
REDIS_URL=redis://redis:6379/0

# === 监控配置 ===
# Prometheus 指标端点
ENABLE_METRICS=true

# === 安全配置 ===
# 最大生成请求数/分钟
RATE_LIMIT_PER_MINUTE=10

# 最大批量生成数
MAX_BATCH_SIZE=10

# === 高级配置 ===
# 品牌声音预设（JSON 格式）
BRAND_VOICE_PRESETS={}

# 禁用关键词（逗号分隔）
BLOCKED_KEYWORDS=

# 内容审核级别 (none, low, high)
CONTENT_MODERATION_LEVEL=low

# === 模板配置 ===
# 模板文件路径
TEMPLATES_FILE=data/templates.json

# 是否使用模板
USE_TEMPLATES=true
