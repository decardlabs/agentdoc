# 钉钉智能客服 Agent 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# === 钉钉配置 ===
# 钉钉应用 AppKey（企业内部应用）
DINGTALK_APP_KEY=your_app_key_here

# 钉钉应用 AppSecret
DINGTALK_APP_SECRET=your_app_secret_here

# 钉钉自定义机器人 Webhook URL（群聊机器人）
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# === LLM 配置 ===
# OpenAI API Key
OPENAI_API_KEY=sk-your_openai_key_here

# LLM 模型 (可选: gpt-4o-mini, gpt-4o, claude-3.5-sonnet)
LLM_MODEL=gpt-4o-mini

# === 后台 API 配置 ===
# 后台 API 基础 URL
BACKEND_API_BASE=https://api.example.com

# 后台 API Key
BACKEND_API_KEY=your_backend_api_key_here

# === 应用配置 ===
# 服务端口（默认 8002，避免与其他主题冲突）
APP_PORT=8002

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Session 过期时间（秒）
SESSION_EXPIRE=3600

# === 数据库配置 ===
# Redis URL
REDIS_URL=redis://redis:6379/0

# === 监控配置 ===
# Prometheus 指标端点
ENABLE_METRICS=true

# === 安全配置 ===
# 允许的用户 ID 列表（逗号分隔，留空表示允许所有）
ALLOWED_USERS=

# 敏感词列表（逗号分隔）
SENSITIVE_WORDS=

# === 高级配置 ===
# 最大消息长度
MAX_MESSAGE_LENGTH=500

# 最大历史轮数
MAX_HISTORY_TURNS=10

# 意图识别置信度阈值
INTENT_CONFIDENCE_THRESHOLD=0.7

# === 转人工配置 ===
# 人工客服排队地址
HUMAN_AGENT_QUEUE_URL=

# 工作时间（用于判断是否转人工）
WORK_HOURS_START=9
WORK_HOURS_END=18
