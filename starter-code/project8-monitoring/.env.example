# ============================================================
# 环境变量示例 - 智能体工程师培养计划 项目 8
# 用途：定义所有需要的环境变量，作为配置模板
# ============================================================

# ============ LangSmith 配置 ============
# LangSmith API Key（用于 LLM 调用追踪）
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__your-langsmith-key-here
LANGCHAIN_PROJECT=agent-monitoring

# ============ 监控配置 ============
# Prometheus 端口
PROMETHEUS_PORT=9090

# Grafana 配置
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
GRAFANA_URL=http://localhost:3000

# 指标服务器端口
METRICS_PORT=8001

# ============ 成本追踪配置 ============
# 全局日预算（美元）
DAILY_BUDGET=10.0

# 全局月预算（美元）
MONTHLY_BUDGET=200.0

# 用户日预算（美元）
USER_DAILY_BUDGET=2.0

# 数据库路径
DB_PATH=llm_logs.db

# ============ 日志配置 ============
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============ 告警配置 ============
# 钉钉 Webhook URL
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN

# 飞书 Webhook URL
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN

# 告警去重时间（秒）
ALERT_DEDUP_SECONDS=300

# ============ 监控 API 配置 ============
# 监控 API 端口
MONITORING_API_PORT=8002

# 监控 API 主机
MONITORING_API_HOST=0.0.0.0

# ============ OpenTelemetry 配置（可选） ============
# 是否启用 OTel 追踪
OTEL_ENABLED=false

# OTel 导出器端点
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# 服务名称
OTEL_SERVICE_NAME=agent-service
