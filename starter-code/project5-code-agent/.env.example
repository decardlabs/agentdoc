# ============ OpenAI 配置 ============
# 必填：OpenAI API 密钥
OPENAI_API_KEY=sk-your-openai-api-key-here

# 可选：自定义 API 地址（如使用 Azure OpenAI 或第三方兼容接口）
OPENAI_BASE_URL=

# 可选：代码生成使用的模型名，默认 gpt-4o-mini
MODEL_NAME=gpt-4o-mini

# ============ E2B 沙箱配置 ============
# 必填：E2B API 密钥
# 获取方式：访问 https://e2b.dev 注册（支持 GitHub 登录）
# 免费版限制：每月 100 小时沙箱使用时长
E2B_API_KEY=your-e2b-api-key-here

# 可选：E2B 模板名，默认 python3
E2B_TEMPLATE=python3

# 可选：沙箱最长运行时间（秒），默认 300（5 分钟）
E2B_TIMEOUT=300

# ============ 执行配置 ============
# 代码执行超时时间（秒），默认 60
EXECUTION_TIMEOUT=60

# 最大自动修复重试次数，默认 3
MAX_RETRIES=3

# ============ 输出配置 ============
# 本地图表和报告保存目录
OUTPUT_DIR=./output

# ============ 日志配置 ============
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
