# ============================================================
# 环境变量示例 - 智能体工程师培养计划 项目7
# 用途：定义所有需要的环境变量，作为配置模板
# 使用方法：
#   1. 复制此文件为 .env：cp .env.example .env
#   2. 编辑 .env，填入真实的配置值
#   3. 不要将 .env 提交到 Git（已在 .gitignore 中）
# ============================================================

# ============ LLM API Keys ============
# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============ 数据库密码 ============
# Redis 密码
REDIS_PASSWORD=redis123

# PostgreSQL 密码
POSTGRES_PASSWORD=agent123

# ============ 端口配置 ============
# Agent 应用端口
APP_PORT=8000

# Redis 端口
REDIS_PORT=6379

# PostgreSQL 端口
POSTGRES_PORT=5432

# Chroma 端口
CHROMA_PORT=8001

# ============ 日志配置 ============
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============ 安全配置 ============
# 应用密钥（用于 JWT 等加密操作）
# 至少 32 个字符，建议使用随机生成的字符串
SECRET_KEY=your-random-secret-key-at-least-32-chars

# CORS 允许的源（逗号分隔）
# 生产环境应设置为具体的域名
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ============ 监控配置 ============
# Grafana 用户名
GRAFANA_USER=admin

# Grafana 密码
GRAFANA_PASSWORD=admin123

# ============ 部署环境 ============
# 部署环境：development, staging, production
DEPLOY_ENV=production

# ============ Docker 配置 ============
# Docker 镜像标签
DOCKER_TAG=latest

# Docker 镜像名称
DOCKER_IMAGE_NAME=multi-agent

# ============ 域名配置 ============
# API 域名（用于 Nginx 配置）
API_DOMAIN=api.your-domain.com

# ============ SSL 配置 ============
# Let's Encrypt 邮箱
LETSENCRYPT_EMAIL=your-email@your-domain.com

# ============ 资源限制 ============
# Agent 应用最大内存（MB）
AGENT_MAX_MEMORY=2048

# Agent 应用最大 CPU 核数
AGENT_MAX_CPUS=2.0

# ============ 健康检查 ============
# 健康检查路径
HEALTH_CHECK_PATH=/health

# 健康检查间隔（秒）
HEALTH_CHECK_INTERVAL=30

# ============ 备份配置 ============
# 备份保留天数
BACKUP_RETENTION_DAYS=7

# 备份目录
BACKUP_DIR=/opt/backups/multi-agent
