# ============ OpenAI 配置 ============
# 必填：OpenAI API 密钥
OPENAI_API_KEY=sk-your-openai-api-key-here

# 可选：自定义 API 地址（如使用 Azure OpenAI 或第三方兼容接口）
OPENAI_BASE_URL=

# 可选：使用的模型名，默认 gpt-4o-mini
MODEL_NAME=gpt-4o-mini

# ============ 编排器配置 ============
# 最大修订次数（审校不通过时打回给写作者），默认 2
MAX_REVISIONS=2

# 是否启用批评者 Agent（对文章进行深度评价），默认 true
ENABLE_CRITIC=true

# 是否启用人工审核节点（审校通过后等待人工确认），默认 false
ENABLE_HUMAN_REVIEW=false

# ============ API 服务配置 ============
# API 绑定地址，默认 0.0.0.0（允许外部访问）
API_HOST=0.0.0.0

# API 监听端口，默认 8000
API_PORT=8000

# ============ 测试配置 ============
# 是否运行需要 LLM 的测试（需要消耗 API 额度），默认 0（跳过）
RUN_LLM_TESTS=0

# ============ 日志配置 ============
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
