# ============================================================
# 环境变量示例 - 智能体工程师培养计划 项目 9
# 用途：定义所有需要的环境变量，作为配置模板
# ============================================================

# =========== 安全配置 ============
# 是否启用输入过滤
ENABLE_INPUT_FILTER=true

# 是否启用输出过滤
ENABLE_OUTPUT_FILTER=true

# 是否启用 LLM 语义检测
ENABLE_LLM_DETECTION=true

# 最大输入长度（字符）
MAX_INPUT_LENGTH=10000

# ============ LLM API Keys ============
# OpenAI API Key（用于语义检测）
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key（可选）
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============ 角色权限 ============
# 默认用户角色（guest / user / power / admin）
DEFAULT_USER_ROLE=user

# 是否启用二次确认
ENABLE_CONFIRMATION=true

# 是否启用审计日志
ENABLE_AUDIT_LOG=true

# ============ 评估配置 ============
# 评估模型
EVAL_MODEL=gpt-4o-mini

# 评估维度权重
WEIGHT_ACCURACY=0.25
WEIGHT_SAFETY=0.40
WEIGHT_HELPFULNESS=0.20
WEIGHT_CONCISENESS=0.15

# 通过阈值（0-1）
PASS_THRESHOLD=0.70

# ============ Red Teaming 配置 ============
# 是否启用 Red Teaming
ENABLE_RED_TEAMING=false

# 变异器数量
MUTATOR_COUNT=3

# 每个基础 Payload 生成的变异数量
VARIANT_COUNT=5

# ============ 日志配置 ============
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 是否启用审计日志
ENABLE_AUDIT_LOG=true

# 审计日志路径
AUDIT_LOG_PATH=./logs/audit.log

# ============ 数据库配置 ============
# 数据库 URL
DATABASE_URL=sqlite:///./security.db

# ============ 告警配置 ============
# 是否启用告警
ENABLE_ALERTS=true

# 告警阈值（风险分数）
ALERT_THRESHOLD=0.85

# 钉钉 Webhook URL（可选）
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# 飞书 Webhook URL（可选）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
